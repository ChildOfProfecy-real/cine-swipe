# ========================================
# CineSwipe Backend — Production Config
# ========================================
# Copy this file to .env and fill in real values.

# PostgreSQL connection string (from Supabase → Settings → Database)
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Secret key for signing JWT tokens (use a long random string, e.g. openssl rand -hex 32)
JWT_SECRET="your-jwt-secret-here"

# Supabase project URL (from Supabase → Settings → API)
SUPABASE_URL="https://your-project.supabase.co"

# Supabase service role key (NOT the anon key — used for server-side storage access)
SUPABASE_SERVICE_KEY="your-service-role-key"

# Supabase storage bucket name
STORAGE_BUCKET="media"

# Port for the Express server
PORT=3001

# Allowed CORS origins (comma-separated for multiple)
# Set to your admin panel URL in production
CORS_ORIGIN="https://your-admin-panel.vercel.app"

# Node environment (set to 'production' in production!)
NODE_ENV="production"

# Razorpay Payment Gateway (get live keys from dashboard.razorpay.com after KYC)
RAZORPAY_KEY_ID="rzp_live_XXXXXXXX"
RAZORPAY_KEY_SECRET="your-live-secret"
RAZORPAY_PLAN_ID="plan_XXXXXXXX"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

