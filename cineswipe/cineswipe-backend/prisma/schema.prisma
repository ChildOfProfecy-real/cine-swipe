generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String               @id @default(cuid())
  email         String               @unique
  password      String
  name          String?
  isAdmin       Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  emailVerified Boolean              @default(false)
  comments      Comment[]
  resetTokens   PasswordResetToken[]
  payments      Payment[]
  subscription  Subscription?
  lists         UserList[]
  watchProgress WatchProgress[]
}

model Movie {
  id            String          @id @default(cuid())
  title         String
  description   String
  thumbnailUrl  String
  heroUrl       String?
  trailerUrl    String?
  genre         String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  clips         Clip[]
  comments      Comment[]
  lists         UserList[]
  watchProgress WatchProgress[]
}

model WatchProgress {
  id        String   @id @default(cuid())
  userId    String
  movieId   String
  clipId    String?
  timestamp Float    @default(0)
  updatedAt DateTime @updatedAt
  clip      Clip?    @relation(fields: [clipId], references: [id])
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
}

model Clip {
  id            String          @id @default(cuid())
  movieId       String
  videoUrl      String
  sequence      Int
  duration      Int
  createdAt     DateTime        @default(now())
  movie         Movie           @relation(fields: [movieId], references: [id], onDelete: Cascade)
  watchProgress WatchProgress[]

  @@unique([movieId, sequence])
  @@index([movieId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  movieId   String
  content   String
  createdAt DateTime @default(now())
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserList {
  id      String @id @default(cuid())
  userId  String
  movieId String
  type    String
  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId, type])
}

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @unique
  razorpaySubId    String?   @unique
  razorpayPlanId   String?
  status           String    @default("FREE")
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  razorpayPaymentId String?  @unique
  razorpayOrderId   String?
  amount            Int
  status            String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
